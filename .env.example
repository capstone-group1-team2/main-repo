# -----------------------------------------------------------------------------
# Environment configuration — Agentic Customer Support Assistant
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must NEVER be committed. Generate your own free Groq API key rather than
# sharing one — see ARCHITECTURE.md §13.
#
# ingestion/config.py and app/config.py are the ONLY two modules in this
# codebase allowed to call os.environ directly. Every other module imports
# its settings from one of those two files. If a variable below isn't read by
# one of them, something is out of sync — fix the config file, not this list.
# -----------------------------------------------------------------------------

# --- Groq LLM API (read by app/config.py) -----------------------------------
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_DEFAULT=llama-3.1-8b-instant
GROQ_MODEL_UPGRADE=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3
GROQ_RETRY_BACKOFF_SECONDS=1.0
GROQ_CIRCUIT_BREAKER_MIN_REMAINING_PCT=0.10

# --- Weaviate (read by ingestion/config.py AND app/config.py) ---------------
# Use "localhost" when running the backend/ingestion directly on the host.
# docker-compose overrides these to the in-network service name ("weaviate")
# for the containerized backend automatically — you don't need to change
# this file for that.
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION_NAME=Chunk

# --- Neo4j (read by ingestion/config.py AND app/config.py) ------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-locally

# --- Redis (read by app/config.py) -------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Ingestion-only paths & model (read by ingestion/config.py) -------------
CORPUS_DIR=data/corpus
HASH_STORE_PATH=ingestion/hash_store.json
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
CHUNK_BUFFER_SIZE=1
CHUNK_BREAKPOINT_PERCENTILE=90

# --- Retrieval / groundedness thresholds (read by app/config.py) -----------
RETRIEVAL_TOP_K=5
MIN_CONFIDENCE_HIGH=0.75
MIN_CONFIDENCE_MED=0.45
GROUNDEDNESS_SIMILARITY_THRESHOLD=0.55
MIN_INTENT_CONFIDENCE=0.6
ANSWER_MATCH_THRESHOLD=0.60
MIN_ESCALATION_DENSE_FLOOR=0.55
MIN_ESCALATION_BM25_FLOOR=4.0

# --- Escalation (read by app/config.py) --------------------------------------
# Leave SLACK_WEBHOOK_URL blank locally if you don't have a webhook yet —
# escalation.py must degrade gracefully, not crash, when it's unset.
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url_here
ESCALATION_STORE_PATH=./eval/escalations.db

# --- Mock order store (read by app/config.py) --------------------------------
MOCK_ORDERS_PATH=data/mock_orders.json

# --- Backend / CORS (read by app/config.py) ----------------------------------
CORS_ORIGINS=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
